{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },
    "jsx": "preserve",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM"],
    "target": "ES2022",
    "strict": false,
    "noEmit": true,
    "allowJs": true,
    "checkJs": false,
    "resolveJsonModule": true
  },
  "include": ["next.config.mjs", "src/**/*.js", "src/**/*.jsx"],
  "exclude": ["node_modules"]
}
