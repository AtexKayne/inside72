# Пример для /etc/nginx/sites-available/inside72
# Скопируйте, подставьте пути к ssl_certificate, затем:
#   sudo ln -sf /etc/nginx/sites-available/inside72 /etc/nginx/sites-enabled/
#   sudo nginx -t && sudo systemctl reload nginx
#
# Важно: редирект www → apex на уровне nginx (быстро, без :3000).
# В GitHub Secrets: NEXT_PUBLIC_SITE_URL=https://inside72.ru (без порта!)

# HTTP → HTTPS
server {
    listen 80;
    listen [::]:80;
    server_name inside72.ru www.inside72.ru;
    return 301 https://inside72.ru$request_uri;
}

# www → основной домен (до Node)
server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name www.inside72.ru;

    ssl_certificate     /etc/letsencrypt/live/inside72.ru/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/inside72.ru/privkey.pem;

    return 301 https://inside72.ru$request_uri;
}

# Основной сайт
server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name inside72.ru;

    ssl_certificate     /etc/letsencrypt/live/inside72.ru/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/inside72.ru/privkey.pem;

    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Forwarded-Host $host;
        # Порт 443 для https — не 3000, иначе Next.js может подставить :3000 в редиректы
        proxy_set_header X-Forwarded-Port 443;

        # Если приложение всё же отдаёт Location с :3000 — переписать
        proxy_redirect http://127.0.0.1:3000/ https://inside72.ru/;
        proxy_redirect http://localhost:3000/ https://inside72.ru/;
        proxy_redirect https://inside72.ru:3000/ https://inside72.ru/;
    }
}
