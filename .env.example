# Переменные окружения (скопируйте в `.env.local`)

# Публичный URL сайта (для SEO, canonical, sitemap)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Хранилище данных:
# — локально по умолчанию JSON в папке data/ (ничего не задавать)
# — на Vercel автоматически Postgres, если задан POSTGRES_URL или DATABASE_URL
# STORAGE_BACKEND=json|postgres
# POSTGRES_URL=postgresql://...
# DATABASE_URL=postgresql://...

# Vercel Blob — загрузка видео для сторис (создаётся в Storage → Blob на Vercel)
# Локально: vercel env pull
BLOB_READ_WRITE_TOKEN=

# Админка: логин по умолчанию `admin`, если не задан ADMIN_USERNAME
ADMIN_USERNAME=admin

# Пароль в открытом виде (только для локальной разработки) ИЛИ хеш ниже для продакшена
ADMIN_PASSWORD=changeme

# Сгенерировать хеш: `node -e "console.log(require('bcryptjs').hashSync('ВАШ_ПАРОЛЬ', 10))"`
# ADMIN_PASSWORD_HASH=

# Секрет подписи JWT (минимум 16 символов)
ADMIN_JWT_SECRET=замените_на_длинную_случайную_строку

# Импорт из VK (сообщество inside_dance72)
# Сервисный ключ приложения (НЕ ключ сообщества):
# vk.com/apps → ваше Standalone-приложение → Настройки → «Сервисный ключ доступа»
VK_SERVICE_KEY=
# Устаревшее имя (тоже работает, если это сервисный ключ, а не ключ группы):
# VK_ACCESS_TOKEN=
# Опционально: числовой id группы (если не задан — определяется по screen name)
# VK_GROUP_ID=
# VK_GROUP_SCREEN_NAME=inside_dance72

# SMTP для формы «пробное занятие» (письма на asantepler@gmail.com)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=app_password
SMTP_FROM=Inside Studio <your@gmail.com>
